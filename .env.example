SPRING_PROFILES_ACTIVE=local
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5434/archive_logitics
SPRING_DATASOURCE_USERNAME=archive
SPRING_DATASOURCE_PASSWORD=archive
ARCHIVE_LEDGER_ENABLED=true
ARCHIVE_LEDGER_BASE_URL=http://localhost:8093
ARCHIVE_LEDGER_BULK_ENDPOINT=/api/events/logistics/bulk
ARCHIVE_LEDGER_CONTRACT_MODE=LOGISTICS_CONFIRMED_NATIVE
ARCHIVE_LEDGER_PUBLISH_TIMEOUT_MS=30000
ARCHIVE_OUTBOX_CHUNK_SIZE=50
ARCHIVE_OUTBOX_MAX_RETRY_COUNT=5
ARCHIVE_OUTBOX_SCHEDULER_ENABLED=true
ARCHIVE_OUTBOX_SCHEDULER_FIXED_DELAY_MS=30000
ARCHIVE_NEXUS_SETTLEMENT_ENABLED=true
ARCHIVE_NEXUS_BASE_URL=http://localhost:8080
ARCHIVE_NEXUS_DAILY_SETTLEMENT_ENDPOINT=/api/logistics/settlements/daily
ARCHIVE_NEXUS_SETTLEMENT_TIMEOUT_MS=30000
ARCHIVE_NEXUS_SETTLEMENT_MAX_RETRY_COUNT=5
ARCHIVE_NEXUS_MANUFACTURING_SHARE_RATE=0.3000
ARCHIVE_NEXUS_SETTLEMENT_SCHEDULER_ENABLED=true
ARCHIVE_NEXUS_SETTLEMENT_SCHEDULER_FIXED_DELAY_MS=300000
ARCHIVE_NEXUS_SETTLEMENT_SCHEDULER_INITIAL_DELAY_MS=45000
ARCHIVE_NEXUS_SETTLEMENT_DATE_OFFSET_DAYS=0
ARCHIVE_ECONOMY_ENABLED=false
ARCHIVE_ECONOMY_PUBLISH_ENABLED=false
JAVA_OPTS=-Xms128m -Xmx384m
